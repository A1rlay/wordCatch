generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model Topic {
  id          String   @id @default(cuid())
  title       String
  description String?
  level       String?
  tags        String[]
  videos      Video[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Video {
  id              String     @id @default(cuid())
  topicId         String
  title           String
  description     String?
  videoUrl        String
  order           Int        @default(0)
  topic           Topic      @relation(fields: [topicId], references: [id], onDelete: Cascade)
  questions       Question[]
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

// ─── QuestionMaker ────────────────────────────────────────────────────────────

enum QMQuestionType {
  MULTIPLE_OPTION
  OPEN_ANSWER
  MATCHER
  CLASSIFIER
}

model QMTopic {
  id          String       @id @default(cuid())
  title       String
  description String?
  order       Int          @default(0)
  questions   QMQuestion[]
  sessions    QMSession[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model QMQuestion {
  id        String         @id @default(cuid())
  topicId   String
  topic     QMTopic        @relation(fields: [topicId], references: [id], onDelete: Cascade)
  order     Int
  type      QMQuestionType
  prompt    String
  data      Json
  answers   QMAnswer[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model QMSession {
  id          String     @id @default(cuid())
  topicId     String
  topic       QMTopic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  answers     QMAnswer[]
  completedAt DateTime?
  createdAt   DateTime   @default(now())
}

model QMAnswer {
  id         String     @id @default(cuid())
  sessionId  String
  session    QMSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  questionId String
  question   QMQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answer     Json
  isCorrect  Boolean?
  reviewedAt DateTime?
  createdAt  DateTime   @default(now())
}

// ─── WordCatch ────────────────────────────────────────────────────────────────

model Question {
  id                String           @id @default(cuid())
  videoId           String
  prompt            String
  order             Int
  checkpointSeconds Int              @default(0)
  video             Video            @relation(fields: [videoId], references: [id], onDelete: Cascade)
  options           QuestionOption[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@unique([videoId, order])
}

model QuestionOption {
  id         String   @id @default(cuid())
  questionId String
  text       String
  isCorrect  Boolean  @default(false)
  order      Int
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([questionId, order])
}
